    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.395.0",
    "next": "14.2.4",
    "node-cron": "^3.0.3",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.3.0",
