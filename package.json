{
  "name": "ezfile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "worker:build": "tsc src/worker.ts --outDir dist --rootDir src --esModuleInterop --skipLibCheck --moduleResolution node --target es2018 --module commonjs",
    "worker": "npm run worker:build && node dist/worker.js"
  },
  "dependencies": {
